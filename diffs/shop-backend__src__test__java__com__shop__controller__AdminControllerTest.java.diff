+@Test @Order(5)

+void testUpdateProduct_Success() throws Exception {

+// Create product first

+String json = objectMapper.writeValueAsString(validProduct());

+String createResp = mockMvc.perform(post("/api/admin/products")

+.with(withAdmin())

+.contentType(MediaType.APPLICATION_JSON)

+.content(json))

+.andReturn().getResponse().getContentAsString();

+

+// Get product ID from list

+String listResp = mockMvc.perform(get("/api/admin/products")

+.with(withAdmin()))

+.andReturn().getResponse().getContentAsString();

+Integer id = extractId(listResp);

+

+if (id != null && id > 0) {

+ProductRequest updateReq = validProduct();

+updateReq.setName("更新名称_" + System.nanoTime());

+String updateJson = objectMapper.writeValueAsString(updateReq);

+mockMvc.perform(put("/api/admin/products/" + id)

+.with(withAdmin())

+.contentType(MediaType.APPLICATION_JSON)

+.content(updateJson))

+.andExpect(status().isOk())

+.andExpect(jsonPath("$.code").value(200));

+}

+}

+

+private Integer extractId(String listResp) {

+try {

+var json = objectMapper.readTree(listResp);

+var records = json.get("data").get("records");

+if (records != null && records.size() > 0) {

+return records.get(0).get("id").asInt();

+}

+} catch (Exception ignored) {}

+return null;

+}

